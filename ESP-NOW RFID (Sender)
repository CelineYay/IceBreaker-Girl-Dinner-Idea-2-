#include <WiFi.h>
#include <esp_now.h>
#include <esp_wifi.h>
#include <SPI.h>
#include <MFRC522.h>

// ================= RFID =================
#define SS_PIN  7
#define RST_PIN 3
MFRC522 mfrc522(SS_PIN, RST_PIN);

// ================= ESP-NOW =================
#define ESPNOW_CHANNEL 1

// ✅ LCD MAC address
//uint8_t lcdMac[] = { 0x20, 0xE7, 0xC8, 0xD2, 0xC6, 0x48 }; //second LCD Board
uint8_t lcdMac[] = { 0x20, 0xE7, 0xC8, 0xD2, 0xC5, 0xE8 }; //first LCD board

typedef struct __attribute__((packed)) {
  char uid[12];
  uint16_t number;
  char name[32];
  char interest[48];
} MatchMsg;

// ================= CARD DATABASE =================
struct Card {
  byte uid[4];
  uint16_t number;
  const char* name;
  const char* interest;
};

Card cards[] = {
  {{0x0B,0xF9,0x29,0x9D},  1, "Abby Lim",      "UX Design"},
  {{0x5B,0x89,0x3A,0x9D},  2, "Bob Liu",        "AIML & IOT"},
  {{0x0B,0xC5,0x3C,0x9D},  3, "Catherine Ko",   "IOT"},
  {{0x7B,0x6E,0x02,0x9D},  4, "David Drapper",  "AIML"},
  {{0xFB,0x16,0x20,0x9D},  5, "Elvin Wong",     "Startups"},
  {{0xFB,0xDD,0x01,0x9D},  6, "Francis Chan",   "Startups & UX Design"},
  {{0x7B,0xF4,0x32,0x9D},  7, "George Teo",     "Startups & AIML"},
  {{0x5B,0xAE,0x27,0x9D},  8, "Henry Toa",      "Startups & IOT"},
  {{0x8B,0x04,0x17,0x9D},  9, "Illhan Su",      "AIML & UX Design"},
  {{0x7B,0x5F,0x4E,0x9D}, 10, "Joshua Luo",     "UX Design & IOT"},
};
int totalCards = sizeof(cards) / sizeof(cards[0]);

// ================= Debounce =================
char lastSentUID[12] = "";
uint32_t lastSentTime = 0;
#define DEBOUNCE_MS 2000

// ================= Helpers =================
Card* findCard(byte *uid) {
  for (int i = 0; i < totalCards; i++) {
    bool match = true;
    for (int j = 0; j < 4; j++) {
      if (uid[j] != cards[i].uid[j]) { match = false; break; }
    }
    if (match) return &cards[i];
  }
  return nullptr;
}

void uidToHex(const MFRC522::Uid &u, char out[12]) {
  snprintf(out, 12, "%02X%02X%02X%02X",
           u.uidByte[0], u.uidByte[1], u.uidByte[2], u.uidByte[3]);
}

// ================= ESP-NOW send tracking =================
volatile bool lastSendDone    = false;
volatile bool lastSendSuccess = false;

void onSendCallback(const wifi_tx_info_t *info, esp_now_send_status_t status) {
  lastSendSuccess = (status == ESP_NOW_SEND_SUCCESS);
  lastSendDone    = true;
}

// ================= ESP-NOW setup =================
void setupEspNow() {
  WiFi.mode(WIFI_STA);
  WiFi.disconnect(); // ✅ do NOT call WiFi.begin() — it causes hang after first send
  delay(100);

  Serial.print("[RFID] MAC: ");
  Serial.println(WiFi.macAddress());

  esp_wifi_set_promiscuous(true);
  esp_wifi_set_channel(ESPNOW_CHANNEL, WIFI_SECOND_CHAN_NONE);
  esp_wifi_set_promiscuous(false);

  // ✅ Lock WiFi channel so it doesn't drift on ESP32-C3
  esp_wifi_set_country_code("SG", true);  // prevents auto-channel changes

  if (esp_now_init() != ESP_OK) {
    Serial.println("[RFID] ESP-NOW init failed!");
    return;
  }

  esp_now_register_send_cb(onSendCallback);

  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, lcdMac, 6);
  peerInfo.channel = ESPNOW_CHANNEL;
  peerInfo.encrypt = false;

  if (esp_now_add_peer(&peerInfo) != ESP_OK) {
    Serial.println("[RFID] Failed to add LCD peer!");
  } else {
    Serial.println("[RFID] ESP-NOW peer added.");
  }
}

// ================= Setup =================
// ⚠️ ESP32-C3: In Arduino IDE, go to Tools and set "USB CDC On Boot" to "Enabled"
//    otherwise Serial prints will NOT appear in Serial Monitor.
void setup() {
  Serial.begin(115200);
  delay(2000); // ✅ ESP32-C3 USB CDC needs extra time to enumerate before printing
  Serial.println("[RFID] Booting...");

  SPI.begin(4, 5, 6, SS_PIN);
  mfrc522.PCD_Init();
  delay(50); // let RC522 settle
  mfrc522.PCD_DumpVersionToSerial(); // ✅ prints RC522 firmware version — confirms SPI works
  Serial.println("[RFID] RC522 ready.");

  setupEspNow();
  Serial.println("[RFID] Tap a card...");
}

// ================= Send with retry =================
#define SEND_RETRIES    3
#define SEND_TIMEOUT_MS 100  // max wait for delivery callback per attempt

bool sendWithRetry(const uint8_t* peer, const uint8_t* data, size_t len) {
  for (int attempt = 1; attempt <= SEND_RETRIES; attempt++) {
    lastSendDone    = false;
    lastSendSuccess = false;

    esp_err_t result = esp_now_send(peer, data, len);
    if (result != ESP_OK) {
      Serial.printf("[RFID] Send attempt %d queue FAIL\n", attempt);
      delay(50);
      continue;
    }

    // ✅ Wait for the delivery callback to confirm success/failure
    uint32_t t0 = millis();
    while (!lastSendDone && (millis() - t0) < SEND_TIMEOUT_MS) {
      delay(1);  // yield to WiFi task on single-core C3
    }

    if (lastSendDone && lastSendSuccess) {
      Serial.printf("[RFID] Delivery SUCCESS (attempt %d)\n", attempt);
      return true;
    }

    Serial.printf("[RFID] Delivery FAILED (attempt %d) — retrying...\n", attempt);
    delay(50);  // small gap before retry
  }

  Serial.println("[RFID] All retries exhausted!");
  return false;
}

// ================= Loop =================
void loop() {
  // Heartbeat every 3 seconds so you know the board is alive
  static uint32_t lastPing = 0;
  if (millis() - lastPing > 3000) {
    lastPing = millis();
    Serial.println("[RFID] waiting for card...");
  }

  // ✅ Re-init RFID reader every 2 seconds instead of every loop
  //    PCD_Init() is heavy SPI traffic — doing it 20x/sec starves the WiFi stack
  static uint32_t lastRFIDInit = 0;
  if (millis() - lastRFIDInit > 2000) {
    lastRFIDInit = millis();
    mfrc522.PCD_Init();
  }

  if (!mfrc522.PICC_IsNewCardPresent()) {
    delay(50);
    return;
  }
  if (!mfrc522.PICC_ReadCardSerial()) {
    delay(50);
    return;
  }

  char hexUID[12];
  uidToHex(mfrc522.uid, hexUID);
  Serial.printf("[RFID] Card detected UID=%s\n", hexUID);

  // Debounce: skip same card tapped too quickly
  uint32_t now = millis();
  if (strcmp(hexUID, lastSentUID) == 0 && (now - lastSentTime) < DEBOUNCE_MS) {
    Serial.println("[RFID] Debounce skip.");
    mfrc522.PICC_HaltA();
    mfrc522.PCD_StopCrypto1();
    delay(100);
    return;
  }
  strncpy(lastSentUID, hexUID, sizeof(lastSentUID));
  lastSentTime = now;

  // Build message
  MatchMsg msg = {};
  strncpy(msg.uid, hexUID, sizeof(msg.uid) - 1);

  Card* c = findCard(mfrc522.uid.uidByte);
  if (c) {
    msg.number = c->number;
    strncpy(msg.name,     c->name,     sizeof(msg.name)     - 1);
    strncpy(msg.interest, c->interest, sizeof(msg.interest) - 1);
    Serial.printf("[RFID] Matched: %s | %s\n", c->name, c->interest);
  } else {
    msg.number = 0;
    strncpy(msg.name,     "Unknown", sizeof(msg.name)     - 1);
    strncpy(msg.interest, "None",    sizeof(msg.interest) - 1);
    Serial.printf("[RFID] Unknown card UID=%s\n", hexUID);
  }

  // ✅ Halt RFID before sending — stops SPI traffic so WiFi stack gets clean air
  mfrc522.PICC_HaltA();
  mfrc522.PCD_StopCrypto1();
  delay(10);  // ✅ brief yield so WiFi task can run on single-core C3

  // Send to LCD with retry
  sendWithRetry(lcdMac, (uint8_t*)&msg, sizeof(msg));

  delay(500); // give card time to leave field
}
