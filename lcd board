// ---------------- Data structures over ESP-NOW ----------------
typedef struct __attribute__((packed)) {
  char uid[12];        // "0BF9299D" + null
  uint16_t number;     // 1..65535
  char name[32];       // adjust if needed
  char interest[48];   // adjust if needed
} MatchMsg;

