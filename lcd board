// ---------------- ESP-NOW receive callback ----------------
void onDataRecv(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  if (len != (int)sizeof(MatchMsg)) return;
  MatchMsg msg;
  memcpy(&msg, data, sizeof(msg));

  // store pending (popup first)
  pendingName = String(msg.name);
  pendingUID  = String(msg.uid);
  pendingNum  = String(msg.number);
  pendingInterest = String(msg.interest);
  pendingConnectionUpdate = true;

  popupName = pendingName;
  popupUID  = pendingUID;
  popupInterest = pendingInterest;

  showPopup = true;
  popupStart = millis();

  // draw rays + popup immediately on top of current screen
  drawRaysBehindPopup();
  drawPopup();
}

void setup() {
  Serial.begin(115200);
  delay(300);

  // Print MAC (you need this for sender)
  WiFi.mode(WIFI_STA);
  Serial.print("[LCD] MAC: ");
  Serial.println(WiFi.macAddress());

  // Force fixed channel for ESP-NOW (must match sender)
  esp_wifi_set_promiscuous(true);
  esp_wifi_set_channel(ESPNOW_CHANNEL, WIFI_SECOND_CHAN_NONE);
  esp_wifi_set_promiscuous(false);

  // Init ESP-NOW
  if (esp_now_init() != ESP_OK) {
    Serial.println("[LCD] ESP-NOW init failed!");
  } else {
    esp_now_register_recv_cb(onDataRecv);
    Serial.println("[LCD] ESP-NOW ready.");
  }

  // LCD reset (TCA9554 via I2C)
  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.beginTransmission(0x20); Wire.write(0x03); Wire.write(0xFE); Wire.endTransmission();
  Wire.beginTransmission(0x20); Wire.write(0x01); Wire.write(0xFF); Wire.endTransmission();
  delay(10);
  Wire.beginTransmission(0x20); Wire.write(0x01); Wire.write(0xFE); Wire.endTransmission();
  delay(20);
  Wire.beginTransmission(0x20); Wire.write(0x01); Wire.write(0xFF); Wire.endTransmission();
  delay(200);

  pinMode(PIN_BL, OUTPUT);
  digitalWrite(PIN_BL, HIGH);
  gfx->begin();

  // Optional: set a fixed time so header isn't blank without internet
  // (If you want NTP, you can connect WiFi, but not required for ESP-NOW)
  struct tm t = {0};
  t.tm_year = 2026 - 1900; t.tm_mon = 1; t.tm_mday = 1;
  t.tm_hour = 12; t.tm_min = 0; t.tm_sec = 0;
  time_t epoch = mktime(&t);
  struct timeval tv = { epoch, 0 };
  settimeofday(&tv, NULL);

  drawScreen();
  drawClock();
}

void loop() {
  // update clock only when popup isn't showing
  if (!showPopup && millis() - lastClock >= 1000) {
    lastClock = millis();
    drawClock();
  }

  // close popup after 3 seconds -> THEN apply latest connection and redraw
  if (showPopup && millis() - popupStart > 3000) {
    showPopup = false;

    if (pendingConnectionUpdate) {
      connectedName     = pendingName;
      connectedUID      = pendingUID;
      connectedNum      = pendingNum;
      connectedInterest = pendingInterest;
      hasConnection = true;
      pendingConnectionUpdate = false;
    }

    drawScreen();
    drawClock();
  }

  delay(5);
}
